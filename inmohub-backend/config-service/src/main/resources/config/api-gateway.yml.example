# Configuración por defecto (Entorno Local/IDE)
server:
  port: 8080

spring:
  cloud:
    gateway:
      server:
        webflux:
          discovery:
            locator:
              enabled: false # Se desactivan las rutas automáticas para tener control manual y preciso
              lower-case-service-id: false

          # Definición de las Rutas
          routes:
            # --- AUTH-SERVICE
            - id: auth-service
              # "lb://" indica Load Balanced. El Gateway pregunta a Eureka qué IPs tienen el servicio
              # "AUTH-SERVICE" y balancea la carga entre ellas si hubiera más de una instancia.
              uri: lb://AUTH-SERVICE
              predicates:
                # Cualquier petición que empieza por /api/v1/auth/ se envía a este microservicio
                - Path=/api/v1/auth/**

            # --- PROPERTY-SERVICE
            - id: property-service
              uri: lb://PROPERTY-SERVICE
              predicates:
                - Path=/api/v1/properties/**

            - id: fsbo-ingestor-service
              uri: lb://FSBO-INGESTOR-SERVICE
              predicates:
                - Path=/api/v1/fsbo/**

            - id: lead-service
              uri: lb://LEAD-SERVICE
              predicates:
                - Path=/api/v1/leads/**

eureka:
  instance:
    # En entorno local, es preferible la IP para evitar conflictos de resolución de nombres de host
    prefer-ip-address: true
  client:
    register-with-eureka: true
    fetch-registry: true
    service-url:
      defaultZone: http://localhost:8761/eureka/
    # Frecuencia con la que el Gateway refresca la lista de servicios disponibles
    # (5 segundos para rapidez en el desarrollo)
    registry-fetch-interval-seconds: 5

jwt:
  secret: "TU_CLAVE_SECRETA_AQUI"
  expiration: 900000 # 15 minutos en milisegundos
  refresh-expiration: 604800000 # 7 días en milisegundos

# Configuración específica para Docker
---
spring:
  config:
    activate:
      on-profile: docker

eureka:
  client:
    service-url:
      # URL interna del service-registry dentro de la red Docker
      defaultZone: http://service-registry:8761/eureka/