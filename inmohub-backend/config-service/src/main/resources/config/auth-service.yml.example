# Configuración por defecto (Entorno Local/IDE)
server:
  port: 8081

spring:
  datasource:
    url: jdbc:mysql://localhost:3307/auth_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
    username: YOUR_DB_USERNAME
    password: YOUR_DB_PASSWORD
    driver-class-name: com.mysql.cj.jdbc.Driver
  jpa:
    hibernate:
      ddl-auto: update # Actualiza el esquema automáticamente (recomendable solo para desarrollo)
    show-sql: true # Muestra las queries en consola para depuración
  kafka:
    producer:
      bootstrap-servers: localhost:9092
      key-serializer: org.apache.kafka.common.serialization.StringSerializer
      value-serializer: org.apache.kafka.common.serialization.StringSerializer

eureka:
  instance:
    prefer-ip-address: true
  client:
    service-url:
      defaultZone: http://localhost:8761/eureka

jwt:
  secret: "TU_CLAVE_SECRETA_AQUI"
  expiration: 900000 # 15 minutos en milisegundos
  refresh-expiration: 604800000 # 7 días en milisegundos

springdoc:
  api-docs:
    path: /api-docs
  swagger-ui:
    path: /swagger-ui.html
    enabled: true

# Configuración específica para Docker
---
spring:
  config:
    activate:
      on-profile: docker # Se activa solo cuando el contenedor tiene SPRING_PROFILES_ACTIVE=docker
  datasource:
    # Uso del nombre del servicio auth-db definido en docker-compose (DNS interno de Docker)
    url: jdbc:mysql://auth-db:3306/auth_db?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
  kafka:
    producer:
      bootstrap-servers: broker:29092
      key-serializer: org.apache.kafka.common.serialization.StringSerializer
      value-serializer: org.apache.kafka.common.serialization.StringSerializer

eureka:
  client:
    service-url:
      defaultZone: http://service-registry:8761/eureka/
  instance:
    # Fuerza el uso de la IP interna del contenedor en lugar del hostname del sistema operativo.
    prefer-ip-address: true

springdoc:
  api-docs:
    path: /api-docs
  swagger-ui:
    path: /swagger-ui.html
    enabled: true
